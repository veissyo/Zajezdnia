<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Zajezdnia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Zajezdnie" asp-action="Index">
            <i class="bi bi-bus-front-fill me-2"></i>Zajezdnia
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Zajezdnie" asp-action="Index">
                        <i class="bi bi-list-ul me-1"></i>Zajezdnie
                    </a>
                </li>
                @if (ViewBag.IsLoggedIn == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Zajezdnie" asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i>Dodaj zajezdnię
                        </a>
                    </li>
                }
            </ul>

            <ul class="navbar-nav ms-auto align-items-center gap-2">
                @if (ViewBag.IsLoggedIn == true)
                {
                    <li class="nav-item">
                        <span class="navbar-text text-white-50 small">
                            <i class="bi bi-person-check-fill me-1"></i>
                            @ViewBag.UserImie @ViewBag.UserNazwisko
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Wyloguj" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Wyloguj
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Zaloguj">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Zaloguj
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Rejestruj">
                            <i class="bi bi-person-plus me-1"></i>Zarejestruj się
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="flex-grow-1 py-4">
    <div class="container">
        @if (TempData["Sukces"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Sukces"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Blad"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Blad"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<footer class="bg-light border-top py-3 mt-auto">
    <div class="container text-center text-muted small">
        &copy; @DateTime.Now.Year Zajezdnia Autobusowa &mdash; ASP.NET Core 9
    </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
