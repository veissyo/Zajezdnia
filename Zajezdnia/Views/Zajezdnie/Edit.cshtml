@model Zajezdnia.Models.Zajezdnia_autobusow
@{
    ViewData["Title"] = "Edytuj zajezdnię";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edytuj zajezdnię</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    @await Html.PartialAsync("_FormZajezdnia", Model)
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-warning flex-fill">
                            <i class="bi bi-check-lg me-1"></i>Zapisz zmiany
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }