@model Zajezdnia.Models.Zajezdnia_autobusow
@{
    ViewData["Title"] = Model.Nazwa;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Zajezdnie</a></li>
        <li class="breadcrumb-item active">@Model.Nazwa</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-0">@Model.Nazwa</h2>
        <p class="text-muted mb-0">
            <i class="bi bi-geo-alt me-1"></i>@Model.Adres &mdash;
            <i class="bi bi-pin-map me-1"></i>@Model.Miasto
        </p>
    </div>
    @if (ViewBag.IsLoggedIn == true)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Edytuj
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash me-1"></i>Usuń
            </a>
        </div>
    }
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0">
            <i class="bi bi-bus-front me-2 text-primary"></i>
            Autobusy (@Model.Autobusy.Count)
        </h5>
    </div>

    @if (!Model.Autobusy.Any())
    {
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-bus-front display-4 opacity-25 d-block mb-2"></i>
            Brak autobusów w tej zajezdni.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nr rejestracyjny</th>
                        <th>Marka</th>
                        <th>Rok prod.</th>
                        <th>Miejsc</th>
                        <th>Kolor</th>
                        <th>Typ</th>
                        <th>Kierowcy</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Autobusy)
                    {
                        <tr>
                            <td class="fw-semibold">@a.NumerRejestracyjny</td>
                            <td>@a.Marka</td>
                            <td>@a.RokProdukcji</td>
                            <td>@a.LiczbaMiejsc</td>
                            <td>@a.Kolor</td>
                            <td><span class="badge bg-secondary">@a.Typ</span></td>
                            <td>
                                @if (a.Kierowcy.Any())
                                {
                                    @string.Join(", ", a.Kierowcy.Select(k => $"{k.Imie} {k.Nazwisko}"))
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Wróć do listy
    </a>
</div>
